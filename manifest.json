{
  "manifest_version": "0.3",
  "name": "word-mcp-live",
  "version": "1.3.0",
  "description": "The only MCP server that edits Word documents while they're open. Live editing, tracked changes, per-action undo, comments, and 114 tools for complete Word document control.",
  "author": {
    "name": "Yüce Karapazar",
    "url": "https://github.com/ykarapazar"
  },
  "repository": {
    "url": "https://github.com/ykarapazar/word-mcp-live",
    "type": "git"
  },
  "license": "MIT",
  "server": {
    "type": "python",
    "entry_point": "word_mcp_server.py",
    "mcp_config": {
      "command": "uvx",
      "args": ["word-mcp-live"],
      "env": {
        "MCP_AUTHOR": "Author",
        "MCP_AUTHOR_INITIALS": ""
      }
    }
  },
  "keywords": ["word", "docx", "microsoft-word", "document", "com-automation", "tracked-changes", "live-editing"]
}
